<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_dark">

    <!-- Search bar + history -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginTop="12dp">

        <!-- Search input row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/search_bg">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginStart="14dp"
                android:src="@drawable/ic_search"
                android:tint="@color/text_muted"
                android:contentDescription="Search" />

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:paddingStart="10dp"
                android:paddingEnd="4dp"
                android:hint="Search songs, artists…"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_muted"
                android:textSize="14sp"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:singleLine="true" />

            <ImageButton
                android:id="@+id/btnClearSearch"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_close"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/text_muted"
                android:visibility="gone"
                android:contentDescription="Clear"
                android:padding="8dp" />
        </LinearLayout>

        <!-- Search history chips -->
        <HorizontalScrollView
            android:id="@+id/scrollHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:scrollbars="none"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/llHistoryChips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="4dp" />

        </HorizontalScrollView>

    </LinearLayout>

    <!-- Multi-select action bar -->
    <LinearLayout
        android:id="@+id/selectionBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/surface_card"
        android:paddingStart="14dp"
        android:paddingEnd="8dp"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/btnCancelSelection"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_primary"
            android:contentDescription="Cancel" />

        <TextView
            android:id="@+id/tvSelectionCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:text="0 selected" />

        <ImageButton
            android:id="@+id/btnSelectAll"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_select_all"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_primary"
            android:contentDescription="Select all"
            android:layout_marginEnd="4dp" />

        <android.widget.Button
            android:id="@+id/btnAddSelected"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Add to playlist"
            android:textSize="12sp"
            android:textColor="@color/white"
            android:background="@drawable/play_btn_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

    </LinearLayout>

    <!-- Song list -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSongs"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="8dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        <LinearLayout
            android:id="@+id/llEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_music_note_bg"
                android:alpha="0.25"
                android:contentDescription="Empty" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="No music found"
                android:textColor="@color/text_muted"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Add audio files to your device"
                android:textColor="@color/text_muted"
                android:textSize="13sp" />
        </LinearLayout>

    </FrameLayout>

</LinearLayout>
