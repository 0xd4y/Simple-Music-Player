<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MuzioLite" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorPrimaryVariant">@color/purple_light</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_accent</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="colorControlNormal">@color/text_muted</item>
        <item name="colorControlActivated">@color/purple_primary</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.MuzioLite.Dialog</item>
    </style>

    <style name="ThemeOverlay.MuzioLite.Dialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="android:background">@color/surface_dialog</item>
        <item name="colorSurface">@color/surface_dialog</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_muted</item>
    </style>

    <style name="TabTextAppearance" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:textSize">13sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
</resources>
